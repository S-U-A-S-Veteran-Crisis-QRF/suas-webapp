# Form delivery via Web3Forms (https://web3forms.com) — free, no backend.
# Every site form (Contact, Pilot, Family Intake, Partner) routes here.
# Get a free access key (enter jacobsilver@suasqrf.org, no account needed); the key
# is emailed to you and is safe to expose in client code.
# Either set it here for local builds, or paste it directly into
# lib/submitForm.ts (the WEB3FORMS_ACCESS_KEY constant).
NEXT_PUBLIC_WEB3FORMS_KEY=

# Deploy sub-path. On GitHub Pages project site it must be /suas-webapp.
# Leave empty for local dev or a root custom domain (e.g. suasqrf.org).
NEXT_PUBLIC_BASE_PATH=
