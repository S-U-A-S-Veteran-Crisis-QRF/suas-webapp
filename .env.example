# Family Intake email delivery (optional). When set, the /api/family-intake
# route emails submissions via Resend (https://resend.com). Without it, the
# route still validates and logs submissions server-side.
RESEND_API_KEY=

# Where intake submissions are emailed. Falls back to jacobsilver@suasqrf.org.
INTAKE_NOTIFY_TO=jacobsilver@suasqrf.org

# Verified sender for Resend (must be a domain you've verified in Resend).
INTAKE_NOTIFY_FROM=SUAS Intake <intake@suasqrf.org>
